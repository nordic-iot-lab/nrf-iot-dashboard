PORT=8080

# MQTT settings
MQTT_BROKER_URL=mqtts://mqtt.mecho.top:8883
MQTT_TOPIC=sensor/+/data
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password
MQTT_CLIENT_ID=nordic-web-dashboard
# WARNING: true disables broker certificate verification. Use only for local debugging.
MQTT_ALLOW_INSECURE_TLS=false
MQTT_CA_CERT_PATH=/app/certs/ca.pem

# Optional bearer token for read endpoints: /api/nodes, /api/nodes/:id, /sensor, history.
# Leave empty only for private lab networks.
READ_AUTH_TOKEN=

# Direct CoAP server is disabled in the EMQX gateway deployment.
COAP_ENABLED=false
COAP_HOST=0.0.0.0
COAP_PORT=5683
# Required if COAP_ENABLED=true in production. Payload must include token or authToken.
COAP_AUTH_TOKEN=

# Leave puller empty when MQTT/EMQX is the single source of truth.
UPSTREAM_PULL_URL=
UPSTREAM_PULL_INTERVAL_MS=5000
UPSTREAM_PULL_TIMEOUT_MS=5000
UPSTREAM_AUTH_TOKEN=

# Required. Set a strong random token before deploying.
API_WRITE_TOKEN=

# PostgreSQL telemetry storage and history
# By default history query topic follows MQTT_TOPIC by replacing '+' with node id.
# You can also set explicit template like: sensor/{nodeId}/data
HISTORY_TOPIC_TEMPLATE=sensor/{nodeId}/data
PG_ENABLED=true
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=nordic
PG_USER=nordic
PG_PASSWORD=change_me
PG_SSL=false
PG_SSL_REJECT_UNAUTHORIZED=true
PG_CONNECT_TIMEOUT_MS=3000
PG_QUERY_TIMEOUT_MS=4000
