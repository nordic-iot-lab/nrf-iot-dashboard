PORT=8080

# MQTT settings (use your own broker / credentials)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC=sensor/+/data
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=nordic-web-dashboard

# CoAP server (nRF can push directly to this service)
COAP_ENABLED=true
COAP_HOST=0.0.0.0
COAP_PORT=5683

# Pull telemetry from your own server REST endpoint (optional)
# Supports response shape: [{...}] or {"items":[...]} or {"nodes":[...]}
UPSTREAM_PULL_URL=https://coap.mecho.top/sensor
UPSTREAM_PULL_INTERVAL_MS=8000
UPSTREAM_AUTH_TOKEN=

# Historical query from PostgreSQL mqtt_messages table
PG_ENABLED=false
PG_HOST=
PG_PORT=5432
PG_DATABASE=mqtt
PG_USER=
PG_PASSWORD=
PG_SSL=false
PG_CONNECT_TIMEOUT_MS=3000
PG_QUERY_TIMEOUT_MS=4000
