PORT=8080

# MQTT settings (use your own broker / credentials)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC=nrf/+/telemetry
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=nordic-web-dashboard

# Pull telemetry from your own server REST endpoint (optional)
# Supports response shape: [{...}] or {"items":[...]} or {"nodes":[...]}
UPSTREAM_PULL_URL=
UPSTREAM_PULL_INTERVAL_MS=8000
UPSTREAM_AUTH_TOKEN=
